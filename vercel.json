{
  "buildCommand": "cd scraper-agent/web && npm install && npm run build",
  "outputDirectory": "scraper-agent/web/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "http://51.21.130.214:3000/api/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
